# Database
DATABASE_URL=sqlite:///./data/sap.db

# URSSAF API
URSSAF_API_BASE=https://portailapi-sandbox.urssaf.fr
URSSAF_CLIENT_ID=your_client_id
URSSAF_CLIENT_SECRET=your_client_secret

# Swan API (Indy bank)
SWAN_API_URL=https://api.swan.io/sandbox-partner/graphql
SWAN_ACCESS_TOKEN=your_swan_token

# Encryption
FERNET_KEY=your_fernet_key_here

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@sap-facture.fr

# App
APP_ENV=development
APP_SECRET_KEY=your_secret_key
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
