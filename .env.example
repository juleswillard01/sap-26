# Google Sheets API
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json
GOOGLE_SCOPES=spreadsheets,drive
SHEETS_CACHE_TTL=30
SHEETS_RATE_LIMIT=60
SHEETS_TIMEOUT=30

# Circuit breaker
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Date format (ISO)
DATE_FORMAT=ISO

# Fiscalité micro-entrepreneur
TAUX_CHARGES_MICRO=0.258
ABATTEMENT_BNC=0.34
CREDIT_IMPOT_CLIENT=0.50

# Timers (heures)
REMINDER_HOURS=36
EXPIRATION_HOURS=48
POLLING_INTERVAL_HOURS=4

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Indy (app.indy.fr) — Playwright export
INDY_EMAIL=
INDY_PASSWORD=

# AIS (avance-immediate.fr)
AIS_EMAIL=
AIS_PASSWORD=
AIS_BASE_URL=https://app.avance-immediate.fr

# Application
APP_ENV=development
APP_PORT=8000
EXPORT_OUTPUT_DIR=./io/exports
