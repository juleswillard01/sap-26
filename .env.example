# ============================================================================
# SAP-Facture Configuration — NEVER COMMIT .env FILE
# ============================================================================
# Copy this file to .env and fill in your credentials
# .env must be in .gitignore (add: echo ".env*" >> .gitignore)
#
# SECURITY: All secrets below must be rotated quarterly
# See: docs/phase3/security-review.md (Section: Gestion des Secrets)
# ============================================================================

# ============================================================================
# URSSAF OAuth2 Authentication
# ============================================================================
# Get credentials from: https://portailapi.urssaf.fr/
# Instructions: docs/phase1/03-urssaf-api-requirements.md
# Sandbox: https://api-sandbox.urssaf.fr (for testing)
#
URSSAF_CLIENT_ID=your_client_id_here_replace_me
URSSAF_CLIENT_SECRET=your_client_secret_here_replace_me
URSSAF_API_BASE_URL=https://portailapi.urssaf.fr

# ============================================================================
# Swan API Configuration (Banking)
# ============================================================================
# Get API key from: https://docs.swan.io/
# WARNING: This key grants access to bank account transactions
# Rotate quarterly (see docs/phase3/security-review.md)
#
SWAN_API_KEY=your_swan_api_key_here_replace_me
SWAN_API_BASE_URL=https://api.swan.io
# For testing/sandbox: https://sandbox.swan.io

# ============================================================================
# Google Service Account (for Sheets + Drive API)
# ============================================================================
# CRITICAL: DO NOT STORE JSON FILE ON DISK
# Instead, encode JSON as base64 and store below
#
# To generate base64 key:
# 1. Go to https://console.cloud.google.com/
# 2. Create Service Account (IAM & Admin → Service Accounts)
# 3. Download JSON key to temp file
# 4. Encode: base64 -i /path/to/service-account.json | tr -d '\n'
# 5. Paste below (single line, remove any newlines)
# 6. Delete JSON file from disk
#
GOOGLE_SERVICE_ACCOUNT_B64=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...your_base64_encoded_json_here...

# Google Sheets ID (the spreadsheet ID from the URL)
# Example URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheets_id_here_replace_me

# Google Drive Folder ID (where invoice PDFs are stored)
# Right-click folder in Drive → Get link → copy ID from URL
SHEETS_DRIVE_FOLDER_ID=your_drive_folder_id_here_replace_me

# ============================================================================
# SMTP Email Configuration
# ============================================================================
# Used for sending reminder emails (T+36h if client hasn't validated)
# For production, use Gmail with App Password (recommended)
#
# Gmail Setup:
#   1. Enable 2-Factor Authentication
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password below (NOT your Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here_replace_me

# Email "From" address for reminders
SMTP_FROM_EMAIL=noreply@sap-facture.example.com

# ============================================================================
# API Security Configuration
# ============================================================================
# Internal API key (for authenticating HTTP requests to FastAPI)
# Generate strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Minimum 32 characters, use alphanumeric + symbols
#
API_KEY_INTERNAL=generate_strong_random_key_32_chars_minimum_replace_me

# Fernet encryption key (for encrypting PII at rest in Phase 2)
# Only needed if enabling data-at-rest encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_ENCRYPTION_KEY=your_fernet_key_here_optional

# ============================================================================
# Application Configuration
# ============================================================================
# Debug mode (MUST be false in production)
# If true, error messages and stack traces will be visible
APP_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use INFO or WARNING in production
APP_LOG_LEVEL=INFO

# Environment: development, staging, production
# Controls security enforcement (HTTPS, header validation, etc.)
ENVIRONMENT=production

# ============================================================================
# Polling & Timeout Configuration
# ============================================================================
# How often to poll URSSAF for payment status updates (hours)
PAYMENT_POLLING_INTERVAL_HOURS=4

# API timeout (seconds) for external calls
API_TIMEOUT_SECONDS=30

# ============================================================================
# Feature Flags (for Phase 2+)
# ============================================================================
# Enable bank reconciliation (Swan integration)
ENABLE_BANK_RECONCILIATION=true

# Enable email reminders (SMTP integration)
ENABLE_EMAIL_REMINDERS=true

# Enable NOVA reporting (quarterly metrics)
ENABLE_NOVA_REPORTING=true

# ============================================================================
# Optional: Future Database Configuration
# ============================================================================
# Only needed if migrating from Google Sheets to SQL (Phase 3+)
# DATABASE_URL=postgresql://user:password@localhost:5432/sap_facture
# DATABASE_URL=sqlite:///./data/sap.db

# Optional: Redis for caching (Phase 2+)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Optional: Monitoring & Error Tracking
# ============================================================================
# Sentry DSN for centralized error tracking
# Create account: https://sentry.io/
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Google Cloud Logging (for production)
# Requires SERVICE_ACCOUNT_JSON with logging:write permission
# ENABLE_CLOUD_LOGGING=true

# ============================================================================
# CORS Configuration (for frontend)
# ============================================================================
# Comma-separated list of allowed origins
# Restrict to your domain only (no localhost in production)
CORS_ORIGINS=https://sap-facture.example.com

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
#
# 1. NEVER COMMIT THIS FILE
#    .env is in .gitignore — verify with: git check-ignore .env
#
# 2. NEVER SHARE THIS FILE
#    Not via email, Slack, GitHub, or any platform
#    Treat like a password file
#
# 3. NEVER LOG THESE VALUES
#    Pydantic SecretStr masks values in logs
#    But check logs for accidental leaks
#
# 4. ROTATE SECRETS QUARTERLY
#    - URSSAF_CLIENT_SECRET
#    - SWAN_API_KEY
#    - SMTP_PASSWORD
#    - API_KEY_INTERNAL
#    - GOOGLE_SERVICE_ACCOUNT_B64 (annually)
#    See: docs/phase3/security-review.md (Section: Secrets Rotation)
#
# 5. IF ACCIDENTALLY COMMITTED
#    Immediately rotate ALL secrets
#    See: docs/INCIDENT_RESPONSE.md
#
# 6. BACKUP SECURELY
#    Keep encrypted backup of .env (not in git repo)
#    Store separately from source code
#
# ============================================================================
# Questions? See: docs/phase3/security-review.md
# ============================================================================
