{
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONPATH": "src",
    "LOG_LEVEL": "DEBUG",
    "MAX_THINKING_TOKENS": "15000"
  },
  "permissions": {
    "allow": [
      "Bash(uv run ruff*)",
      "Bash(uv run pyright*)",
      "Bash(uv run pytest*)",
      "Bash(uv run python*)",
      "Bash(uv sync*)",
      "Bash(uv add*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*credentials*.json)",
      "Read(*service-account*)"
    ]
  }
}
